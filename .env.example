# ResQRoute — Environment Configuration
# Copy to .env and fill in your keys

# Google Vertex AI (Gemini LLM)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/vertex-sa.json

# TomTom (Primary traffic + routing)
TOMTOM_API_KEY=your-tomtom-api-key

# Google Maps (Fallback routing + geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Mapbox (Frontend map rendering)
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# GNews (News corroboration)
GNEWS_API_KEY=your-gnews-api-key

# City configuration
CITY_NAME=Bengaluru
CITY_LAT=12.9716
CITY_LNG=77.5946
CITY_RADIUS_KM=30

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
